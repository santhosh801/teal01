# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Security ─────────────────────────────────────────────────────────────────
# Change this to a strong random secret in production
API_KEY=trackz-assignment-key

# ─── Feed ─────────────────────────────────────────────────────────────────────
FEED_URL=https://mock-data.tealvue.in

# ─── Symbols ──────────────────────────────────────────────────────────────────
# Comma-separated list of symbols to subscribe to
SYMBOLS=RELIANCE,TCS

# ─── State ────────────────────────────────────────────────────────────────────
# Max ticks kept in memory per symbol
MAX_TICKS_PER_SYMBOL=500

# ─── Alerts ───────────────────────────────────────────────────────────────────
# Max alerts kept in memory
MAX_ALERTS=100
